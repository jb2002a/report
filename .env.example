# =============================================================================
# Equity Report RAG — environment template
# Copy to .env and fill in your values:
#   copy .env.example .env
# =============================================================================

# --- Required (pipeline) -------------------------------------------------------
OPENAI_API_KEY=sk-proj-your-openai-key-here
LLAMA_CLOUD_API_KEY=llx-your-llama-cloud-key-here

# --- LangSmith (tracing; recommended) ----------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-key-here
LANGSMITH_PROJECT=equity-report-rag-mvp

# --- Vector store ------------------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=equity_reports

# --- Models --------------------------------------------------------------------
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- Retrieval & chunking ----------------------------------------------------
RETRIEVAL_TOP_K=6
MIN_CONTEXT_CHUNKS=2
CHUNK_SIZE=1000
CHUNK_OVERLAP=120
CHUNK_MIN_TEXT_CHARS=150

# --- Debug ---------------------------------------------------------------------
EXPORT_DEBUG_CHUNKS=false

# =============================================================================
# Optional — not used by equity_rag by default (extra="ignore" in Settings)
# Keep here if you use the same .env for other notebooks/tools.
# =============================================================================

# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GOOGLE_API_KEY=your-google-api-key-here
# GROQ_API_KEY=gsk_your-groq-key-here
# HF_TOKEN=hf_your-huggingface-token-here
# UPSTAGE_API_KEY=up_your-upstage-key-here
# LANGTRACE_API_KEY=your-langtrace-key-here
# WANDB_API_KEY=wandb_your-wandb-key-here
# WANDB_PROJECT=your-wandb-project-name
